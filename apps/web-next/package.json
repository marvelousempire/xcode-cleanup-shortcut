{
  "name": "@dustpan/web-next",
  "private": true,
  "version": "0.26.1",
  "description": "Next.js app for DustPan by AVERY GOODMAN. Built as a static export so the Python server (web/server.py) can serve it without a Node runtime. Reachable via ?next=1 alongside the Vite (default) and vanilla (?legacy=1) UIs.",
  "scripts": {
    "dev": "next dev --port 5175",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint --max-warnings 0"
  },
  "dependencies": {
    "lucide-react": "^0.469.0",
    "next": "^14.2.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
