#!/bin/bash
# DustPan CLI wrapper — invokes the AppleScript with env-flags from CLI args.
# Renamed from "Xcode Cleanup" in v0.21.0; bin name stays `xcc` for muscle-memory.
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Resolve symlinks so this works whether xcc is symlinked into ~/.local/bin or run directly.
if [ -L "${BASH_SOURCE[0]}" ]; then
  SCRIPT_DIR="$(cd "$(dirname "$(readlink "${BASH_SOURCE[0]}")")" && pwd)"
fi
SCRIPT="$SCRIPT_DIR/../dustpan.applescript"

# Hard fail fast if the script isn't where we expect it — gives a clear error
# instead of a confusing osascript "file not found".
if [ ! -f "$SCRIPT" ]; then
  echo "✗ DustPan script not found at: $SCRIPT" >&2
  echo "  Run xcc from inside a DustPan repo clone, or reinstall:" >&2
  echo "    cd /path/to/dustpan && make install-cli" >&2
  exit 1
fi

usage() {
  cat <<USAGE
Usage: xcc [flags]

Reclaim Xcode disk space: DerivedData, iOS/watchOS/tvOS DeviceSupport,
SwiftPM caches, unavailable simulators, and /tmp orphans.

Flags:
  --dry-run        Measure what would be freed; delete nothing
  --demo           Simulate phases (for screen recording)
  --force          Skip the 50 GB free threshold check
  --auto-confirm   Skip the confirmation alert (use with --dry-run, etc.)
  --patterns GLOB  Override /tmp orphan globs ("" skips phase 4 entirely)
  --no-update-check  Skip the daily GitHub release check
  --history        Print last 20 entries from the run log and exit
  --report         Print sparkline of freed-GB across recent runs and exit
  --version, -V    Print version and exit
  --help, -h       This message
USAGE
}

env_args=()
while [ $# -gt 0 ]; do
  case "$1" in
    --help|-h) usage; exit 0 ;;
    --version|-V) grep '^property kVersion' "$SCRIPT" | awk -F'"' '{print "xcc " $2}'; exit 0 ;;
    --history) tail -20 ~/Library/Logs/dustpan.log 2>/dev/null || echo "No runs logged yet."; exit 0 ;;
    --report) python3 "$SCRIPT_DIR/../scripts/report.py"; exit $? ;;
    --dry-run) env_args+=("DUSTPAN_DRY_RUN=1"); shift ;;
    --demo) env_args+=("DUSTPAN_DEMO=1"); shift ;;
    --force) env_args+=("DUSTPAN_FORCE=1"); shift ;;
    --auto-confirm) env_args+=("DUSTPAN_AUTO_CONFIRM=1"); shift ;;
    --no-update-check) env_args+=("DUSTPAN_NO_UPDATE_CHECK=1"); shift ;;
    --patterns) env_args+=("DUSTPAN_TMP_PATTERNS=$2"); shift 2 ;;
    *) echo "Unknown flag: $1" >&2; usage >&2; exit 1 ;;
  esac
done

exec env "${env_args[@]}" osascript "$SCRIPT"
